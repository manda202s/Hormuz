# Strait of Hormuz Monitor - Environment Variables

# ---- APIs ----
# MarineTraffic API for ship tracking (https://marinetraffic.com/en/ais/api-services)
MARINETRAFFIC_API_KEY=

# Alpha Vantage for oil prices fallback (https://alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# ---- Redis (Upstash) ----
# Get free tier at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Analytics (optional) ----
NEXT_PUBLIC_GA_ID=

# ---- Base URL ----
NEXT_PUBLIC_BASE_URL=https://middleeaststraitofhormuz.com
